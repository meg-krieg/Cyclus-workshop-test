{
    "name": "Cyclus Workshop Test",
    "image": "ghcr.io/cyclus/cymetric_24.04_apt/cymetric:latest",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "username": "vscode",
            "userUid": "automatic",
            "userGid": "automatic"
        },
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "remoteUser": "vscode",
    "updateRemoteUserUID": true,
    "waitFor": "postStartCommand",
    "postCreateCommand": "echo 'export LC_ALL=C; unset LANGUAGE' >> ~/.bashrc && /usr/bin/python3 -m pip install --user --upgrade ipykernel --break-system-packages",
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.vscode-xml",
                "ms-python.python",
                "qwtel.sqlite-viewer",
                "alexcvzz.vscode-sqlite",
                "ms-toolsai.jupyter"
            ]
        }
    }
}
